# =====================================================
# GradShow Student App — Environment Variables
# =====================================================
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك

# ----- API Configuration -----
# رابط Laravel API server
# في التطوير المحلي: http://localhost:8000/api
# في الإنتاج: https://api.gradshow.com/api
VITE_API_URL=http://localhost:8000/api

# ----- Mock Data Toggle -----
# true  = استخدم بيانات وهمية (لا يحتاج Laravel)
# false = استخدم Laravel API الحقيقي
VITE_USE_MOCK=false

# ----- App Configuration -----
# عنوان التطبيق (يظهر في الإشعارات والـ meta tags)
VITE_APP_NAME=GradShow
